URIDEMO_BIND_HOST=0.0.0.0
URIDEMO_PUBLIC_HOST=127.0.0.1
URIDEMO_PORT=39785
URIDEMO_PORT_FALLBACK=auto

URIDEMO_NODE_HOST=127.0.0.1
URIDEMO_NODE_PORT=18081

URIDEMO_API_PATH=/api/dispatch
URIDEMO_CONFIG_PATH=/api/config
URIDEMO_HEALTH_PATH=/health
URIDEMO_FRONTEND_PATH=/examples/frontend.html
URIDEMO_JS_MODULE_PATH=/js/index.js

URIDEMO_DEVICE_ID=device-01
URIDEMO_PROCESS_TARGET=bridge
URIDEMO_LOG_LIMIT=50
URIDEMO_LOG_STORE_LIMIT=200
URIDEMO_REFRESH_MS=1500
URIDEMO_HEALTH_TIMEOUT_SECONDS=10
URIDEMO_HEALTH_POLL_SECONDS=0.2
URIDEMO_HTTP_TIMEOUT_SECONDS=5

URI_DEVICE_LED_SET=device://device-01/led/command/set
URI_DEVICE_PING_SEND=device://device-01/ping/command/send
URI_DEVICE_STATE_CURRENT=device://device-01/state/query/current
URI_DEVICE_TELEMETRY_LATEST=device://device-01/telemetry/query/latest

URI_PROCESS_SMOKE=process://bridge/command/smoke

URI_LOG_FRONTEND_SESSION_WRITE=log://frontend/session/command/write
URI_LOG_FRONTEND_ACTION_WRITE=log://frontend/action/command/write
URI_LOG_BACKEND_ACTION_WRITE=log://backend/action/command/write
URI_LOG_BACKEND_PROCESS_WRITE=log://backend/process/command/write
URI_LOG_BACKEND_DEVICE_WRITE=log://backend/device/command/write
URI_LOG_BACKEND_LOGS_RECENT=log://backend/logs/query/recent
URI_LOG_FIRMWARE_ACTION_WRITE=log://firmware/action/command/write
URI_LOG_FIRMWARE_DEVICE_WRITE=log://firmware/device-01/command/write
URI_LOG_SHELL_ACTION_WRITE=log://shell/action/command/write
